# ============================================
# RE/MAX Altitud — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# ---- Database (PostgreSQL via Coolify) ----
DATABASE_URL=                          # PostgreSQL connection string (postgresql://user:pass@host:5432/dbname)

# ---- RE/MAX CCA API ----
REMAX_API_BASE_URL=                    # RE/MAX CCA API base URL
PZ_OFFICE_GUID=                        # Pérez Zeledón office GUID
DOM_OFFICE_GUID=                       # Dominical/Uvita (Altitud Cero) office GUID

# ---- Translation APIs ----
DEEPL_API_KEY=                         # DeepL API key for translation
OPENAI_API_KEY=                        # OpenAI API key for SEO metadata generation

# ---- Maps (client-safe) ----
NEXT_PUBLIC_MAPBOX_TOKEN=              # Mapbox GL JS access token (safe for client)

# ---- Security / Cron ----
CRON_SECRET=                           # Secret for cron job authentication
API_SECRET=                            # Secret for internal API route authentication

# ---- Monitoring ----
SENTRY_DSN=                            # Sentry DSN for error tracking (server-side)
NEXT_PUBLIC_SENTRY_DSN=                # Sentry DSN for error tracking (client-side, safe for browser)
SENTRY_ORG=                            # Sentry organization slug (for source map uploads)
SENTRY_PROJECT=                        # Sentry project slug (for source map uploads)
SENTRY_AUTH_TOKEN=                     # Sentry auth token (for source map uploads in CI)
NEXT_PUBLIC_GA_MEASUREMENT_ID=         # Google Analytics 4 measurement ID (safe for client)
