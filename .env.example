# ============================================
# RE/MAX Altitud — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# ---- Database (Supabase) ----
SUPABASE_URL=                          # Supabase project URL (https://xxx.supabase.co)
SUPABASE_ANON_KEY=                     # Supabase anonymous/public key
SUPABASE_SERVICE_ROLE_KEY=             # Supabase service role key (server-only, never expose)
DATABASE_URL=                          # PostgreSQL connection string (postgresql://...)

# ---- RE/MAX CCA API ----
REMAX_API_BASE_URL=                    # RE/MAX CCA API base URL
PZ_OFFICE_GUID=                        # Pérez Zeledón office GUID
DOM_OFFICE_GUID=                       # Dominical/Uvita (Altitud Cero) office GUID

# ---- Translation APIs ----
DEEPL_API_KEY=                         # DeepL API key for translation
OPENAI_API_KEY=                        # OpenAI API key for SEO metadata generation

# ---- Maps (client-safe) ----
NEXT_PUBLIC_MAPBOX_TOKEN=              # Mapbox GL JS access token (safe for client)

# ---- Security / Cron ----
CRON_SECRET=                           # Secret for cron job authentication
API_SECRET=                            # Secret for internal API route authentication

# ---- Monitoring ----
SENTRY_DSN=                            # Sentry DSN for error tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=         # Google Analytics 4 measurement ID (safe for client)
